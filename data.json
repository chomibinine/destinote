<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <title>무료운세 사주 타로 토정비결 점성술 | 소름돋는 운세</title>
    <meta name="description" content="사주 엔진의 끝판왕 로직 탑재! 합충파해 및 지장간 분석으로 소름 돋는 정확도를 경험하세요.">
    <link rel="canonical" href="https://your-domain.com/">
    
    <script src="https://cdn.jsdelivr.net/npm/lunar-javascript/lunar.min.js"></script>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <style>
        @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
        
        :root { 
            --bg-base: #05070a; --bg-gradient: radial-gradient(circle at 50% 0%, #111724 0%, #05070a 100%); 
            --card-glass: rgba(18, 22, 33, 0.6); --card-border: rgba(255, 255, 255, 0.08); 
            --accent-gold: #d4af37; --accent-gold-light: #f9e596; --premium-gradient: linear-gradient(135deg, #f9e596 0%, #d4af37 100%); 
            --text-main: #e2e8f0; --text-muted: #94a3b8; 
            --color-wood: #4ade80; --color-fire: #fb923c; --color-earth: #fbbf24; --color-metal: #cbd5e1; --color-water: #60a5fa; 
        }

        * { box-sizing: border-box; font-family: 'Pretendard', sans-serif; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; word-break: keep-all; overflow-wrap: break-word; }
        body { background: var(--bg-base); color: var(--text-main); line-height: 1.8; overflow-x: hidden; min-height: 100vh; position: relative; }
        
        /* Background & UI Defaults */
        .ambient-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; pointer-events: none; background: var(--bg-gradient); }
        .orb { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.35; animation: float 20s infinite alternate ease-in-out; }
        .orb-1 { width: 450px; height: 450px; background: rgba(212,175,55,0.15); top: -100px; left: -150px; }
        .orb-2 { width: 550px; height: 550px; background: rgba(56,189,248,0.1); bottom: -200px; right: -150px; animation-delay: -5s; }
        @keyframes float { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(50px,50px) scale(1.1); } }

        .app-container { max-width: 720px; margin: 0 auto; padding: 0 20px 160px; position: relative; z-index: 1; }
        .header { text-align: center; padding: 80px 0 50px; }
        .header h1 { color: #fff; font-size: 2.6rem; font-weight: 800; letter-spacing: 6px; background: var(--premium-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 12px; }
        .header p { font-size: 0.95rem; color: var(--text-muted); letter-spacing: 2px; }

        .privacy-notice { background: rgba(255,255,255,0.02); border: 1px solid var(--card-border); border-radius: 20px; padding: 18px 24px; margin-bottom: 35px; font-size: 0.9rem; color: var(--text-muted); display: flex; align-items: flex-start; gap: 14px; line-height: 1.6; }
        .privacy-notice b { color: var(--accent-gold-light); }

        .card { background: var(--card-glass); backdrop-filter: blur(25px); border: 1px solid var(--card-border); border-radius: 35px; padding: 50px 40px; margin-bottom: 50px; }
        .form-group { margin-bottom: 30px; }
        label { display: block; margin-bottom: 12px; font-weight: 600; color: var(--accent-gold-light); font-size: 0.85rem; letter-spacing: 1px; }
        input, select { width: 100%; padding: 20px 24px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.3); color: #fff; font-size: 1.05rem; outline: none; transition: all 0.3s ease; -webkit-appearance: none; appearance: none; }
        input:focus, select:focus { border-color: var(--accent-gold); background: rgba(0,0,0,0.5); }
        .select-row { display: flex; gap: 15px; } .select-row select { margin-bottom: 0; }

        .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 70px; }
        .menu-item { background: var(--card-glass); border: 1px solid var(--card-border); border-radius: 30px; padding: 45px 20px; text-align: center; cursor: pointer; transition: all 0.4s ease; }
        .menu-item:hover { border-color: var(--accent-gold); transform: translateY(-8px); }
        .menu-icon-wrap { width: 75px; height: 75px; margin: 0 auto 24px; background: rgba(255,255,255,0.03); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid var(--card-border); font-size: 2.4rem; transition: 0.4s ease; }
        .menu-item:hover .menu-icon-wrap { background: rgba(212,175,55,0.15); border-color: var(--accent-gold); transform: scale(1.1); }
        .menu-item h3 { font-size: 1.2rem; color: #fff; font-weight: 700; margin-bottom: 8px; }
        .menu-item p { font-size: 0.85rem; color: var(--text-muted); }

        #result-view, #tarot-pick-view { display: none; animation: slideUpFade 0.8s ease forwards; }
        @keyframes slideUpFade { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
        .fade-in-section { opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease; }
        .fade-in-section.is-visible { opacity: 1; transform: none; }

        /* Report UI - 복구된 화려한 요소들 */
        .daily-fortune { background: linear-gradient(135deg, rgba(212,175,55,0.12), rgba(212,175,55,0.03)); border: 1px solid rgba(212,175,55,0.4); border-radius: 24px; padding: 24px; margin-bottom: 35px; text-align: center; }
        .profile-box { background: linear-gradient(135deg, rgba(212,175,55,0.06), rgba(0,0,0,0.6)); border: 1px solid rgba(212,175,55,0.25); border-radius: 35px; padding: 45px 35px; margin-bottom: 60px; text-align: center; position: relative; overflow: hidden;}
        .profile-box::before { content: ''; position: absolute; top: 0; left: 15%; width: 70%; height: 2px; background: var(--premium-gradient); opacity: 0.6; }
        .profile-box h2 { color: var(--accent-gold-light); margin: 0 0 18px; font-size: 1.9rem; font-weight: 800; letter-spacing: 2px; }
        .profile-box p { color: var(--text-muted); font-size: 0.95rem; margin: 8px 0; font-weight: 400; }
        .profile-box .tag { display: inline-block; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 4px 14px; border-radius: 20px; font-size: 0.8rem; margin-right: 10px; font-weight: 500; }
        
        .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 35px; border-top: 1px solid var(--card-border); padding-top: 35px; }
        .stat-item { background: rgba(0,0,0,0.3); padding: 22px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.03); }
        .stat-label { font-size: 0.8rem; color: var(--text-muted); display: block; margin-bottom: 8px; font-weight: 400; }
        .stat-val { font-size: 1.2rem; color: var(--accent-gold); font-weight: 700; }

        .sec-title { font-size: 1.5rem; color: var(--accent-gold-light); font-weight: 800; margin: 90px 0 35px; display: flex; align-items: center; gap: 15px; }
        .sec-title::before { content: '✦'; font-size: 1.3rem; color: var(--accent-gold); }
        .detail-text { font-size: 1.1rem; line-height: 2.0; color: var(--text-main); font-weight: 400; text-align: justify; } 
        .detail-text p { margin-bottom: 24px; } 
        .detail-text b.basis-text { color: var(--accent-gold-light); font-weight: 700; display: inline-block; margin-bottom: 8px; font-size: 1.05rem; }
        .summary-box { background: linear-gradient(135deg, rgba(212,175,55,0.1) 0%, rgba(0,0,0,0) 100%); border-left: 3px solid var(--accent-gold); border-radius: 0 24px 24px 0; padding: 35px 45px; margin-bottom: 45px; color: #fff; font-weight: 600; font-size: 1.2rem; line-height: 1.8; }

        /* 사주 명식표 */
        .pillar-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 50px; } 
        .pillar { background: rgba(255,255,255,0.03); padding: 30px 10px; border-radius: 24px; text-align: center; border: 1px solid var(--card-border); box-shadow: inset 0 0 25px rgba(0,0,0,0.4);} 
        .pillar span { display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 14px; } 
        .pillar b.stem, .pillar b.branch { color: var(--text-main); font-size: 1.8rem; display: block; margin-bottom: 5px; }
        .pillar .ten-god-top, .pillar .ten-god-bottom { font-size: 0.85rem; color: var(--accent-gold); font-weight: 600; padding: 5px 0;}
        
        .daewun-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 6px; text-align: center; margin-bottom:50px;}
        .daewun-col { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 12px 0; }
        .daewun-age { font-size: 0.75rem; color: var(--accent-gold-light); font-weight: 700; margin-bottom: 6px; }
        .daewun-char { font-size: 1.15rem; color: #fff; font-weight: 700; line-height: 1.3; }

        /* 오행 차트 */
        .element-chart-container { margin: 60px 0; padding: 40px 35px; background: rgba(0,0,0,0.4); border-radius: 35px; border: 1px solid var(--card-border); }
        .element-chart-title { text-align: center; color: #fff; font-weight: 700; margin-bottom: 40px; font-size: 1.2rem; letter-spacing: 1px; }
        .bar-wrap { display: flex; align-items: center; margin-bottom: 22px; gap: 18px; }
        .bar-label { width: 50px; color: var(--text-muted); font-size: 0.9rem; text-align: right; }
        .bar-bg { flex: 1; height: 10px; background: rgba(255,255,255,0.06); border-radius: 10px; position: relative; }
        .bar-fill { height: 100%; border-radius: 10px; transition: width 1.5s ease; width: 0%; }
        .bar-count { width: 35px; font-size: 0.9rem; font-weight: 700; color: #fff; }
        .fill-wood { background: var(--color-wood); box-shadow: 0 0 12px rgba(74, 222, 128, 0.6); } 
        .fill-fire { background: var(--color-fire); box-shadow: 0 0 12px rgba(251, 146, 60, 0.6); } 
        .fill-earth { background: var(--color-earth); box-shadow: 0 0 12px rgba(251, 191, 36, 0.6); } 
        .fill-metal { background: var(--color-metal); box-shadow: 0 0 12px rgba(203, 213, 225, 0.6); } 
        .fill-water { background: var(--color-water); box-shadow: 0 0 12px rgba(96, 165, 250, 0.6); }

        /* 10년 타임라인 */
        .timeline { position: relative; max-width: 100%; margin: 50px 0 70px; padding-left: 25px; } 
        .timeline::before { content: ''; position: absolute; top: 0; left: 8px; height: 100%; width: 2px; background: rgba(212,175,55,0.3); } 
        .timeline-item { position: relative; margin-bottom: 40px; padding-left: 35px; } 
        .timeline-point { position: absolute; left: -28px; top: 6px; width: 16px; height: 16px; background: var(--accent-gold); border-radius: 50%; box-shadow: 0 0 12px rgba(212,175,55,0.8); z-index: 2; } 
        .timeline-year { font-size: 1.3rem; color: var(--accent-gold-light); font-weight: 800; margin-bottom: 10px; display: flex; align-items: center; gap: 12px; } 
        .timeline-animal { display: inline-block; font-size: 0.85rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 14px; color: #fff; } 
        
        /* 토정비결 시각 효과 */
        .tj-code-wrap { text-align: center; margin: 40px 0 70px; } 
        .tj-code-wrap .code { font-size: 4.5rem; font-weight: 800; color: var(--accent-gold); display: block; line-height: 1; letter-spacing: 6px; text-shadow: 0 0 40px rgba(212,175,55,0.5); font-family: 'Times New Roman', serif;}
        .tj-poem-box { background: rgba(0,0,0,0.5); border: 1px solid var(--accent-gold); border-radius: 24px; padding: 50px 40px; text-align: center; margin-bottom: 60px; position: relative;} 
        .tj-poem-box::after { content: '📜'; position: absolute; top: -25px; left: 50%; transform: translateX(-50%); font-size: 2.2rem; background: var(--bg-base); padding: 0 20px; } 
        .tj-month-card { background: rgba(255,255,255,0.03); border: 1px solid var(--card-border); border-radius: 28px; padding: 40px 35px; margin-bottom: 28px; position: relative; overflow: hidden; } 
        .tj-month-header { display: flex; align-items: baseline; gap: 15px; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 18px; margin-bottom: 24px; } 
        .tj-month-num { font-size: 1.5rem; color: var(--accent-gold-light); font-weight: 800; } 
        
        /* 타로 카드 */
        .tarot-spread { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-top: 35px; justify-items: center; perspective: 1000px; } 
        .tarot-card-container { width: 100%; max-width: 100px; aspect-ratio: 2/3.3; cursor: pointer; } 
        .tarot-card-inner { position: relative; width: 100%; height: 100%; text-align: center; transition: transform 0.8s ease; transform-style: preserve-3d; } 
        .tarot-card-inner.flipped { transform: rotateY(180deg) scale(1.05); pointer-events: none; } 
        .tarot-card-front, .tarot-card-back { position: absolute; width: 100%; height: 100%; -webkit-backface-visibility: hidden; backface-visibility: hidden; border-radius: 14px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--card-border); } 
        .tarot-card-front { background: linear-gradient(135deg, #1a2233, #0b0e14); } 
        .tarot-card-back { background: var(--bg-base); color: #fff; transform: rotateY(180deg); font-size: 2.4rem; border-color: var(--accent-gold); }

        /* 유틸 버튼 및 하단 처방전 */
        .action-box { margin-top: 110px; padding: 70px 45px; border-radius: 45px; background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, rgba(0,0,0,0.4) 100%); border: 1px solid var(--card-border); text-align: center; }
        .btn-rec { display: inline-flex; align-items: center; justify-content: center; gap: 14px; background: rgba(255,255,255,0.04); color: var(--text-main); padding: 22px 35px; border-radius: 20px; text-decoration: none; font-weight: 600; font-size: 1.1rem; border: 1px solid var(--card-border); width: 100%; cursor: pointer; transition: all 0.3s; } 
        .btn-rec:hover { background: var(--premium-gradient); color: #000; font-weight: 800; }
        .utility-buttons { display: flex; gap: 15px; margin-top: 20px; }
        .btn-util { flex: 1; background: var(--card-glass); border: 1px solid var(--card-border); color: #fff; padding: 24px 10px; border-radius: 24px; font-weight: 700; font-size: 1.15rem; cursor: pointer; } 

        .nav-wrapper { position: fixed; bottom: 35px; left: 0; width: 100%; display: flex; justify-content: center; z-index: 9999; pointer-events: none; } 
        .nav { pointer-events: auto; background: rgba(10, 14, 22, 0.9); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 40px; display: flex; width: 90%; max-width: 450px; padding: 10px; } 
        .nav-item { flex: 1; text-align: center; color: var(--text-muted); font-size: 0.75rem; cursor: pointer; padding: 10px 0; } 
        .nav-item.active { color: var(--accent-gold-light); font-weight: 700; } 

        #loader { display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--bg-base); z-index: 100000; flex-direction: column; justify-content: center; align-items: center; } 
        .loader-ring { width: 90px; height: 90px; border: 3px solid transparent; border-top-color: var(--accent-gold); border-radius: 50%; animation: spin 1.5s linear infinite; } 
        @keyframes spin { to { transform: rotate(360deg); } }
        
        @media (max-width: 600px) { 
            .app-container { padding: 0 15px 140px; } 
            .header h1 { font-size: 2rem; } 
            .pillar-row { grid-template-columns: repeat(2, 1fr); gap: 12px; } 
            .daewun-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }
            .utility-buttons { flex-direction: column; gap: 10px; }
        }
    </style>
</head>
<body>

<div class="ambient-bg"><div class="orb orb-1"></div><div class="orb orb-2"></div></div>
<div id="loader"><div class="loader-ring"></div><p id="loader-text" style="color:var(--accent-gold); margin-top:20px; font-weight:700; letter-spacing:3px;">우주적 데이터를 불러오는 중...</p></div>

<div class="app-container" id="main-app" style="display:none;">
    <div id="home-view">
        <header class="header"><h1>소름돋는 운세</h1><p>명리학 끝판왕 DB 연동 완료</p></header>
        <div class="privacy-notice"><i class="icon">🔒</i> <div><b>[내 정보 안전 저장]</b> 기기에만 안전하게 저장됩니다.</div></div>

        <div class="card">
            <div class="form-group"><label>상담 대상 성함</label><input type="text" id="user-name" placeholder="이름 입력"></div>
            <div class="form-group">
                <label>생년월일</label>
                <div class="select-row"><select id="user-year"></select><select id="user-month"></select><select id="user-day"></select></div>
            </div>
            <div class="form-group select-row">
                <div style="flex:1;"><label>성별</label><select id="user-gender"><option value="male">남성</option><option value="female">여성</option></select></div>
                <div style="flex:1;"><label>력 체계</label><select id="user-cal"><option value="solar">양력</option><option value="lunar">음력</option></select></div>
            </div>
            <div class="form-group">
                <label>태어난 시각</label>
                <select id="user-time"><option value="none">모름</option><option value="0">자시</option><option value="2">축시</option><option value="4">인시</option><option value="6">묘시</option><option value="8">진시</option><option value="10">사시</option><option value="12">오시</option><option value="14">미시</option><option value="16">신시</option><option value="18">유시</option><option value="20">술시</option><option value="22">해시</option></select>
            </div>
        </div>
        <div class="menu-grid">
            <div class="menu-item" onclick="handleStart('saju')"><div class="menu-icon-wrap">🧭</div><h3>정밀 사주</h3><p>합충파해/지장간 리포트</p></div>
            <div class="menu-item" onclick="handleStart('tojeong')"><div class="menu-icon-wrap">📜</div><h3>토정비결</h3><p>2026 신년운세</p></div>
            <div class="menu-item" onclick="handleStart('star')"><div class="menu-icon-wrap">✨</div><h3>점성술</h3><p>수호성 매핑</p></div>
            <div class="menu-item" onclick="handleStart('tarot')"><div class="menu-icon-wrap">🃏</div><h3>타로</h3><p>무의식 리딩</p></div>
        </div>
        <div id="visitor-ui" style="text-align:center; font-size:0.8rem; color:var(--text-muted);"></div>
    </div>

    <div id="tarot-pick-view" style="display:none;">
        <header class="header" style="padding: 50px 0 40px;"><h1>무의식의 거울</h1><p>마음을 정돈하고 3장을 고르세요.</p></header>
        <div style="text-align:center; color:var(--text-muted); margin-bottom:30px;">당신의 무의식이 우주적 흐름과 만나는 지점을 투영합니다.</div>
        <div id="tarot-count-info" style="text-align:center; color:var(--accent-gold-light); margin-bottom:30px; font-weight:700;">3장 중 0장 선택됨</div>
        <div class="tarot-spread" id="tarot-spread-area"></div>
        <button class="btn-rec" style="margin-top: 60px; background:var(--bg-base);" onclick="goHome()">🏠 이전으로 돌아가기</button>
    </div>

    <div id="result-view" style="display:none;">
        <div id="report-wrap" class="report-wrapper"><div id="report-content"></div></div>
        <div class="utility-buttons"><button class="btn-util" onclick="downloadImage()">📸 결과 캡처</button><button class="btn-util" onclick="shareReport()">🔗 링크 공유</button></div>
        <button class="btn-rec" onclick="goHome()" style="margin-top:20px; background:var(--bg-base);">🏠 처음으로 돌아가기</button>
    </div>
</div>

<div class="nav-wrapper">
    <nav class="nav">
        <div class="nav-item active" onclick="goHome()">🏠 홈</div>
        <div class="nav-item" onclick="handleStart('saju')">🧭 사주</div>
        <div class="nav-item" onclick="handleStart('tojeong')">📜 토정</div>
        <div class="nav-item" onclick="handleStart('tarot')">🃏 타로</div>
    </nav>
</div>

<script>
    // ==========================================
    // ★ 1. LOGIC CONSTANTS (규칙 및 구조) ★
    // ==========================================
    let MYSTIC_DATA = null;

    const ganHab = { '甲':'己', '己':'甲', '乙':'庚', '庚':'乙', '丙':'辛', '辛':'丙', '丁':'壬', '壬':'丁', '戊':'癸', '癸':'戊' };
    const zhiHab6 = { '子':'丑', '丑':'子', '寅':'亥', '亥':'寅', '卯':'戌', '戌':'卯', '辰':'酉', '酉':'辰', '巳':'申', '申':'巳', '午':'未', '未':'午' };
    const zhiChung = { '子':'午', '午':'子', '丑':'未', '未':'丑', '寅':'申', '申':'寅', '卯':'酉', '酉':'卯', '辰':'戌', '戌':'辰', '巳':'亥', '亥':'巳' };
    const hiddenStems = { '子':['壬','癸'], '丑':['癸','辛','己'], '寅':['戊','丙','甲'], '卯':['甲','乙'], '辰':['乙','癸','戊'], '巳':['戊','庚','丙'], '午':['丙','己','丁'], '未':['丁','乙','己'], '申':['戊','壬','庚'], '酉':['庚','辛'], '戌':['辛','丁','戊'], '亥':['戊','甲','壬'] };
    const motherEls = {'木':'水', '火':'木', '土':'火', '金':'土', '水':'金'};
    const childEls = {'木':'火', '火':'土', '土':'金', '金':'水', '水':'木'};
    const wealthEls = {'木':'土', '火':'金', '土':'水', '金':'木', '水':'火'};
    const powerEls = {'木':'金', '火':'水', '土':'木', '金':'火', '水':'土'};

    // ==========================================
    // ★ 2. HELPER & UI GENERATOR FUNCTIONS ★
    // ==========================================
    function getOh(c) { if('甲乙寅卯'.includes(c)) return '木'; if('丙丁巳午'.includes(c)) return '火'; if('戊己辰戌丑未'.includes(c)) return '土'; if('庚辛申酉'.includes(c)) return '金'; if('壬癸亥子'.includes(c)) return '水'; return ''; }
    function wrap(c) { return `<div class="fade-in-section">${c}</div>`; }
    function UI_Section(title, basis, text, ext="") {
        return wrap(`<div class="sec-title">${title}</div><div class="detail-text" ${ext?'style="margin-bottom:40px;"':''}><p><b class="basis-text">${basis}</b>${text}</p></div>${ext}`);
    }
    function UI_Box(title, content) {
        return wrap(`<div style="background:rgba(255,255,255,0.03); padding:25px; border-radius:24px; border:1px solid var(--card-border); margin-bottom:50px;">
                        ${title ? `<h4 style="color:var(--accent-gold-light); margin-bottom:15px; font-size:1.15rem;">${title}</h4>` : ''}
                        <div class="detail-text" style="font-size:1.05rem;">${content}</div>
                     </div>`);
    }

    function getSingleKeywordLuck(oh) {
        const seed = Math.floor(Math.random() * 9) + 1;
        const p = { '木':{n:'일기장',l:'행운 아이템',i:'📓',d:'정동쪽',c:'그린'}, '火':{n:'디퓨저',l:'행운 아이템',i:'🕯️',d:'정남쪽',c:'레드'}, '土':{n:'다기세트',l:'행운 아이템',i:'🍵',d:'중앙',c:'황색'}, '金':{n:'메탈시계',l:'행운 아이템',i:'⌚',d:'정서쪽',c:'실버'}, '水':{n:'가습기',l:'행운 아이템',i:'💧',d:'정북쪽',c:'블랙'} };
        const item = p[oh] || p['土'];
        return { name: item.n, label: item.l, icon: item.i, dir: item.d, color: item.c, num: seed };
    }

    // ==========================================
    // ★ 3. LOGIC ENGINES ★
    // ==========================================
    function calculateBaseData() {
        const n=document.getElementById('user-name').value, y=parseInt(document.getElementById('user-year').value), m=parseInt(document.getElementById('user-month').value), d=parseInt(document.getElementById('user-day').value), h=document.getElementById('user-time').value, cal=document.getElementById('user-cal').value;
        let hr=h==='none'?12:parseInt(h); let sol,lun;
        if(cal==='solar'){sol=Solar.fromYmdHms(y,m,d,hr,0,0); lun=sol.getLunar();} else {lun=Lunar.fromYmdHms(y,m,d,hr,0,0); sol=lun.getSolar();}
        const bazi=lun.getEightChar(), dG=bazi.getDayGan(), dZ=bazi.getDayZhi(), oh=getOh(dG), seed=n.length+sol.getYear()+sol.getMonth()+sol.getDay()+hr;
        
        const e={'木':0,'火':0,'土':0,'金':0,'水':0}; 
        const ch=[bazi.getYearGan(), bazi.getYearZhi(), bazi.getMonthGan(), bazi.getMonthZhi(), dG, dZ, h==='none'?'':bazi.getTimeGan(), h==='none'?'':bazi.getTimeZhi()];
        ch.forEach(c => { let el = getOh(c); if(el) e[el]++; });
        
        const tenGodsCount = {'비겁':0, '식상':0, '재성':0, '관성':0, '인성':0};
        const calcGod = (target) => { 
            if(!target || target==='모름') return '-'; 
            const tEl = getOh(target);
            if(oh === tEl) return '비겁';
            if(childEls[oh] === tEl) return '식상';
            if(wealthEls[oh] === tEl) return '재성';
            if(powerEls[oh] === tEl) return '관성';
            if(motherEls[oh] === tEl) return '인성';
            return '-';
        };
        const mapping = { yG:calcGod(ch[0]), yZ:calcGod(ch[1]), mG:calcGod(ch[2]), mZ:calcGod(ch[3]), dZ:calcGod(ch[5]), hG:calcGod(ch[6]), hZ:calcGod(ch[7]) };
        let domGod = '비겁', maxG = -1; 
        for(let g of Object.keys(tenGodsCount)){ if(tenGodsCount[g]>maxG){ maxG=tenGodsCount[g]; domGod=g; } }

        // 합화 스캔
        const br = [ch[1], ch[3], ch[5], ch[7]]; let habMsg = '';
        if(br.includes('寅')&&br.includes('午')&&br.includes('戌')) { e['火']+=2; habMsg='지지에 인오술(寅午戌) 화국이 형성되어 불의 기운이 폭발적으로 증폭됩니다.'; }
        else if(br.includes('申')&&br.includes('子')&&br.includes('辰')) { e['水']+=2; habMsg='지지에 신자진(申子辰) 수국이 형성되어 물의 기운이 증폭됩니다.'; }
        
        // 용신/조후 스캔
        const mZ = ch[3]; let yong = '', yRsn = '';
        const mySc = e[oh] + e[motherEls[oh]], opSc = e[childEls[oh]] + e[wealthEls[oh]] + e[powerEls[oh]];
        if(['亥','子','丑'].includes(mZ) && ['木','水','金'].includes(oh)) { yong='火'; yRsn=`한겨울(${mZ}월)에 태어나 꽁꽁 얼어붙어 있으니, 만물을 녹일 [화(火)] 기운이 최우선입니다`; }
        else if(['巳','午','未'].includes(mZ) && ['木','火','土'].includes(oh)) { yong='水'; yRsn=`한여름(${mZ}월) 용광로 사주이니, 열기를 시원하게 식혀줄 [수(水)] 기운이 최우선입니다`; }
        else {
            yong = (mySc > opSc) ? ((e[wealthEls[oh]]>=e[powerEls[oh]])?wealthEls[oh]:powerEls[oh]) : ((e[motherEls[oh]]>=e[oh])?motherEls[oh]:oh);
            if(!yong || e[yong]===0) yong = (mySc > opSc) ? childEls[oh] : motherEls[oh];
            yRsn = (mySc > opSc) ? `신강하여 에너지를 배출할 [${MYSTIC_DATA.YONGSHIN_DB[yong].n}] 기운이 필요합니다` : `신약하여 본원을 생조할 [${MYSTIC_DATA.YONGSHIN_DB[yong].n}] 기운이 필요합니다`;
        }

        // 지장간 스캔
        let hidMsg = ''; const missing = Object.keys(e).filter(k => e[k]===0);
        if(missing.length > 0) {
            let found = false; br.forEach(z => { if(hiddenStems[z] && hiddenStems[z].some(s => getOh(s)===missing[0])) found = true; });
            if(found) hidMsg = `표면에 [${MYSTIC_DATA.YONGSHIN_DB[missing[0]].n}] 기운이 없으나, 지장간(땅속) 깊은 곳에 비밀스럽게 품고 있어 위기 시 거대 자산으로 작용합니다.`;
        }

        // 신살/조력자 스캔
        const shinSal = [];
        const cheonEulMap = {'甲':['丑','未'], '戊':['丑','未'], '庚':['丑','미'], '乙':['子','申'], '己':['子','申'], '丙':['亥','酉'], '丁':['亥','酉'], '辛':['寅','午'], '壬':['巳','卯'], '癸':['巳','卯']};
        ch.forEach(c => { if(cheonEulMap[dG]?.includes(c)) shinSal.push({name:'천을귀인', desc:'인생의 큰 고비마다 하늘이 돕는 절대적인 조력자가 나타납니다.', level:5}); });
        if(br.includes('子')||br.includes('午')||br.includes('卯')||br.includes('酉')) shinSal.push({name:'도화살', desc:'타인을 끌어당기는 묘한 매력과 대중적인 스타성을 지녔습니다.', level:4});
        if(br.includes('寅')||br.includes('申')||br.includes('巳')||br.includes('亥')) shinSal.push({name:'역마살', desc:'한 곳에 머물지 않고 넓은 세계를 누비며 부를 창출하는 활동력을 뜻합니다.', level:4});

        // 대운/세운 스캔
        const cYear = new Date().getFullYear(); const myAge = cYear - sol.getYear() + 1;
        let daewun = []; try{ const dyList=bazi.getYun(1).getDaYun(); for(let i=0;i<8;i++)if(dyList[i])daewun.push({age:dyList[i].getStartAge(), ganzhi:dyList[i].getGanZhi()}); }catch(err){}
        let curDw = daewun.find(d => myAge >= d.age) || daewun[0] || {age:1, ganzhi:'甲子'};
        
        const sG = Lunar.fromDate(new Date()).getYearGan(), sZ = Lunar.fromDate(new Date()).getYearZhi(), sEl = getOh(sG);
        let dyn = [];
        ch.forEach(c => { if(ganHab[c]===sG) dyn.push(`올해 [${sG}] 기운이 당신의 [${c}]과 '천간합'을 이뤄 융합 에너지가 발생합니다.`); });
        ch.forEach(c => { if(zhiChung[c]===sZ) dyn.push(`올해 [${sZ}] 기운이 당신의 [${c}]을 강하게 충격(충)하여 이동수나 청산이 필요합니다.`); });
        
        return { name:n, baziChars:{yG:ch[0],yZ:ch[1],mG:ch[2],mZ:ch[3],dG:ch[4],dZ:ch[5],hG:ch[6],hZ:ch[7]}, mapping, domGod, myGyukguk:mapping.mZ!=='-'?mapping.mZ:domGod, yong, yRsn, habMsg, hidMsg, shinSal, dyn, daewun, curDw, dwStart:curDw.age, dwEnd:curDw.age+9, sG, sZ, sEl, cYear, oh, dG, seed, solStr:`${sol.getYear()}년 ${sol.getMonth()}월 ${sol.getDay()}일`, lunStr:`${lun.getYear()}년 ${lun.getMonth()}월 ${lun.getDay()}일`, e, yC:0 }; // yC 밸런스 로직 간소화
    }

    // ==========================================
    // ★ 4. UI RENDERER (화려했던 100% 원상 복구) ★
    // ==========================================
    function handleStart(type) {
        if(!MYSTIC_DATA) return alert("데이터베이스를 불러오는 중입니다. 잠시만 기다려주세요.");
        if(!document.getElementById('user-name').value) return alert("성함을 입력해주세요.");
        
        document.getElementById('loader').style.display='flex';
        document.getElementById('loader-text').innerText = "운명의 실타래 해독 중...";
        
        setTimeout(() => {
            try {
                if (type === 'tarot') { document.getElementById('loader').style.display='none'; document.getElementById('home-view').style.display='none'; document.getElementById('tarot-pick-view').style.display='block'; renderDeck(); return; }
                const d = calculateBaseData();
                
                // 점성술 및 토정 데이터 추가 계산
                if (type === 'star') {
                    const solM = parseInt(document.getElementById('user-month').value), solD = parseInt(document.getElementById('user-day').value);
                    for (let z of MYSTIC_DATA.ZODIAC_DB) { if ((solM === z.start[0] && solD >= z.start[1]) || (solM === z.end[0] && solD <= z.end[1])) d.zodiac = z; }
                    if(!d.zodiac) d.zodiac = MYSTIC_DATA.ZODIAC_DB[0];
                } else if (type === 'tojeong') {
                    const cal=document.getElementById('user-cal').value, y=parseInt(document.getElementById('user-year').value), m=parseInt(document.getElementById('user-month').value), dy=parseInt(document.getElementById('user-day').value);
                    let lM = m, lD = dy;
                    if(cal==='solar') { const l = Solar.fromYmd(y,m,dy).getLunar(); lM = l.getMonth(); lD = l.getDay(); }
                    const age = new Date().getFullYear() - y + 1;
                    const t = ((y-4)%12)+1; const u = (t+age)%8||8; const w = (lM%2===0)?2:1; const md = (w+lM)%6||6; const l = (lD%10)+1; const lw = (l+lD)%3||3;
                    d.tj = { u, md, lw, c: `${u}${md}${lw}` };
                }

                document.getElementById('loader').style.display='none'; document.getElementById('home-view').style.display='none'; document.getElementById('result-view').style.display='block'; renderFinalReport(type, d);
            } catch(e) { console.error(e); alert("계산 중 오류가 발생했습니다. 생년월일을 확인해주세요."); document.getElementById('loader').style.display='none'; }
        }, 800);
    }

    function renderFinalReport(type, d) {
        // [복구] 프로필 박스 및 음양/코어 스탯 그리드
        let yC = 0; Object.values(d.baziChars).forEach(c => { if('甲丙戊庚壬子寅辰午申戌'.includes(c)) yC++; });
        
        let h = `<div class="daily-fortune"><h3>✨ 오늘의 우주적 메세지</h3><p>"거대한 변화의 파도를 타고 도약하는 시기입니다."</p></div>
                 <div class="profile-box"><h2>${d.name}</h2><p><span class="tag">양력</span> ${d.solStr}</p><p><span class="tag">음력</span> ${d.lunStr}</p>
                 <div class="stat-grid">
                    <div class="stat-item"><span class="stat-label">영혼의 코어 (본원)</span><span class="stat-val">${MYSTIC_DATA.JIGAN_DB[d.dG].name}</span></div>
                    <div class="stat-item"><span class="stat-label">음양 밸런스</span><span class="stat-val">양 ${yC} : 음 ${8-yC}</span></div>
                 </div></div>`;

        if(type==='saju') {
            h += wrap(`<div class="summary-box">귀하의 명식은 [${MYSTIC_DATA.GYUKGUK_DB[d.myGyukguk].n}] 형국으로, 삶의 고비마다 [${MYSTIC_DATA.YONGSHIN_DB[d.yong].n}] 기운을 활용할 때 눈부신 성취를 이룹니다.</div>`);

            // [복구] 사주 명식표 및 대운표
            h += wrap(`<div class="sec-title">사주 명식 및 대운표 (우주적 바코드)</div>
                <div class="pillar-row">
                    <div class="pillar"><span>시주(말년)</span><div class="ten-god-top">${d.mapping.hG}</div><b class="stem">${d.baziChars.hG}</b><b class="branch">${d.baziChars.hZ}</b><div class="ten-god-bottom">${d.mapping.hZ}</div></div>
                    <div class="pillar" style="border-color:var(--accent-gold);"><span>일주(본인)</span><div class="ten-god-top">나(本)</div><b class="stem" style="color:var(--accent-gold-light);">${d.baziChars.dG}</b><b class="branch">${d.baziChars.dZ}</b><div class="ten-god-bottom">${d.mapping.dZ}</div></div>
                    <div class="pillar"><span>월주(청년)</span><div class="ten-god-top">${d.mapping.mG}</div><b class="stem">${d.baziChars.mG}</b><b class="branch">${d.baziChars.mZ}</b><div class="ten-god-bottom">${d.mapping.mZ}</div></div>
                    <div class="pillar"><span>연주(초년)</span><div class="ten-god-top">${d.mapping.yG}</div><b class="stem">${d.baziChars.yG}</b><b class="branch">${d.baziChars.yZ}</b><div class="ten-god-bottom">${d.mapping.yZ}</div></div>
                </div>
                <div style="background:rgba(0,0,0,0.4); border:1px solid var(--card-border); border-radius:24px; padding:30px 25px; margin-bottom:50px;">
                    <h4 style="color:var(--text-muted); font-size:0.95rem; margin-bottom:15px; text-align:center;">내 인생의 10년 주기 환경 [ 大運 ]</h4>
                    <div class="daewun-grid">${d.daewun.map(w => `<div class="daewun-col"><div class="daewun-age">${w.age}세</div><div class="daewun-char">${w.ganzhi.charAt(0)}<br>${w.ganzhi.charAt(1)}</div></div>`).join('')}</div>
                </div>`);

            // [복구] 오행 막대그래프
            h += wrap(`<div class="element-chart-container"><div class="element-chart-title">타고난 오행 에너지 분포도</div>
                <div class="bar-wrap"><div class="bar-label">목(木)</div><div class="bar-bg"><div class="bar-fill fill-wood" style="width:${(d.e['木']/8)*100}%"></div></div><div class="bar-count">${d.e['木']}개</div></div>
                <div class="bar-wrap"><div class="bar-label">화(火)</div><div class="bar-bg"><div class="bar-fill fill-fire" style="width:${(d.e['火']/8)*100}%"></div></div><div class="bar-count">${d.e['火']}개</div></div>
                <div class="bar-wrap"><div class="bar-label">토(土)</div><div class="bar-bg"><div class="bar-fill fill-earth" style="width:${(d.e['土']/8)*100}%"></div></div><div class="bar-count">${d.e['土']}개</div></div>
                <div class="bar-wrap"><div class="bar-label">금(金)</div><div class="bar-bg"><div class="bar-fill fill-metal" style="width:${(d.e['金']/8)*100}%"></div></div><div class="bar-count">${d.e['金']}개</div></div>
                <div class="bar-wrap"><div class="bar-label">수(水)</div><div class="bar-bg"><div class="bar-fill fill-water" style="width:${(d.e['水']/8)*100}%"></div></div><div class="bar-count">${d.e['水']}개</div></div></div>`);

            // 심연의 로직 & 역동성
            let abyss = `<p><b class="basis-text">용신 정밀 타겟팅:</b> ${d.yRsn}.</p>`;
            if(d.habMsg) abyss += `<p><b class="basis-text">오행 변환(合化):</b> ${d.habMsg}</p>`;
            if(d.hidMsg) abyss += `<p><b class="basis-text">지장간(숨겨진 무기):</b> ${d.hidMsg}</p>`;
            h += UI_Section("🌌 심연의 통변: 숨겨진 비밀", "사주의 깊은 곳을 스캔한 결과입니다.", "", UI_Box("", abyss));

            if(d.dyn.length > 0) {
                h += UI_Section("⚡ 운명의 역동성: 합충파해", `올해 ${d.cYear}년의 기운과 사주의 충돌/융합 결과입니다.`, "", UI_Box("", d.dyn.map(msg=>`<p>📍 ${msg}</p>`).join('')));
            }

            let dwText = `현재 [${d.curDw.ganzhi}] 대운 중심을 지나며, ${getOh(d.curDw.ganzhi.charAt(0))===d.yong?'황금기이니 과감히 도전하세요.':'조정기이니 내실을 다지세요.'}`;
            let seunText = `올해 [${d.sG}${d.sZ}년] 세운은 ${d.sEl===d.yong?'대길의 해이니 질주하십시오.':'관망의 해이니 실력을 축적하세요.'}`;
            h += UI_Section("⏳ 현재 운세 기상도", "10년 주기 대운과 올해 세운 스캔:", "", UI_Box(`나의 10년 사이클 (${d.dwStart}~${d.dwEnd}세)`, `<p>${dwText}</p><hr style="border-color:rgba(255,255,255,0.1); margin:15px 0;"><h4 style="color:var(--color-fire); margin-bottom:10px; font-size:1.15rem;">올해 ${d.cYear}년의 흐름</h4><p>${seunText}</p>`));

            // [복구] 일간, 초중말, 분야별, 건강/가족 텍스트
            h += UI_Section("본원의 거울: 일간 기질", d.dG+" 일간의 특징: ", MYSTIC_DATA.JIGAN_DB[d.dG].desc);
            h += UI_Section("🌱 인생 3단계 흐름", "생애 주기별 분석:", `<br><b>초년:</b> ${MYSTIC_DATA.LIFETIME_DB.e[d.oh]}<br><br><b>중년:</b> ${MYSTIC_DATA.LIFETIME_DB.m[d.oh]}<br><br><b>말년:</b> ${MYSTIC_DATA.LIFETIME_DB.l[d.oh]}`);
            h += UI_Section("💎 입체 통변", "오행과 십성 크로스 매칭:", `<br><b>💰 재물:</b> ${MYSTIC_DATA.LIFETIME_DB.w[d.oh]} 또한 [${d.domGod}] 발달로 ${MYSTIC_DATA.GOD_DB[d.domGod]?MYSTIC_DATA.GOD_DB[d.domGod].w:''}<br><br><b>💼 직업:</b> ${MYSTIC_DATA.LIFETIME_DB.c[d.oh]} 특히 ${MYSTIC_DATA.GOD_DB[d.domGod]?MYSTIC_DATA.GOD_DB[d.domGod].c:''} 환경 유리<br><br><b>❤️ 애정:</b> ${MYSTIC_DATA.LIFETIME_DB.l_v[d.oh]} ${MYSTIC_DATA.GOD_DB[d.domGod]?MYSTIC_DATA.GOD_DB[d.domGod].l:''}<br><br><b>👨‍👩‍👧‍👦 가족:</b> ${MYSTIC_DATA.LIFETIME_DB.f[d.oh]}<br><br><b>💪 건강:</b> ${MYSTIC_DATA.LIFETIME_DB.h[d.oh]}`);

            // [복구] 천을귀인 (조력자) 큰 아이콘 박스
            const helper = MYSTIC_DATA.HELPER_DB[d.dG] || MYSTIC_DATA.HELPER_DB['甲'];
            h += wrap(`<div class="sec-title">🤝 조력자 분석: 천을귀인</div><div class="helper-box"><div class="helper-icon">🐂</div><div class="helper-info"><h4>나의 귀인: <span>${helper.animals}</span></h4><p><b class="basis-text" style="display:inline; margin-bottom:0;">일간 ${d.dG}를 돕는 최고의 길신의 위치를 탐색한 결과, </b>${helper.desc}</p></div></div>`);

            // [복구] 특수 신살(도화/역마 등) 렌더링
            if(d.shinSal && d.shinSal.length > 0) {
                let salHtml = `<div class="sec-title">나의 숨겨진 잠재력: 특수 신살(神殺)</div><div class="detail-text" style="margin-bottom:20px;"><p><b class="basis-text">사주 8글자의 합/충/파/해를 정밀하게 스캔하여 찾아낸 귀하만의 특별한 잠재력입니다.</b></p></div><div style="display:grid; grid-template-columns:1fr; gap:15px; margin-bottom:50px;">`;
                d.shinSal.forEach(sal => {
                    let stars = '★'.repeat(sal.level > 5 ? 5 : sal.level);
                    salHtml += `<div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.1); border-left:3px solid var(--accent-gold); border-radius:16px; padding:20px; display:flex; flex-direction:column; justify-content:center;">
                        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
                            <span style="color:#fff; font-weight:700; font-size:1.15rem;">${sal.name}</span>
                            <span style="color:var(--accent-gold-light); font-size:0.9rem; letter-spacing:2px;">${stars}</span>
                        </div>
                        <span style="color:var(--text-muted); font-size:0.95rem; line-height:1.5;">${sal.desc}</span>
                    </div>`;
                });
                salHtml += `</div>`;
                h += wrap(salHtml);
            }

            // [복구] 10년 타임라인 달력 UI
            let timelineHtml = ''; const bA = ['자(쥐)', '축(소)', '인(호랑이)', '묘(토끼)', '진(용)', '사(뱀)', '오(말)', '미(양)', '신(원숭이)', '유(닭)', '술(개)', '해(돼지)'];
            const tA = ["장기적인 안목으로 씨앗을 뿌리기에 완벽한 해입니다.", "다진 기반이 훗날 철옹성이 됩니다.", "과감한 도전을 실행해야 할 타이밍입니다.", "주변의 도움으로 문제를 해결하며 실속을 챙깁니다.", "문서운이 매우 강력하게 들어옵니다.", "역마가 강하게 들어와 타향에서 기회를 얻습니다.", "노력이 화려하게 드러나며 스포트라이트를 받습니다.", "속도를 줄이고 내면과 가정을 돌볼 때 행복을 얻습니다.", "투자보다 본업에 집중하여 현금을 확보하세요.", "예리한 판단력으로 실속을 극대화합니다.", "베풀었던 덕이 되돌아오며 자산을 지키기에 최적입니다.", "낡은 관념을 버리고 완전히 새롭고 위대한 다음을 기획하십시오."];
            for(let i=0; i<10; i++) { let y=d.cYear+i; let idx=(y-4)%12; timelineHtml += `<div class="timeline-item"><div class="timeline-point"></div><div class="timeline-year">${y}년 <span class="timeline-animal">${bA[idx]}의 해</span></div><div class="timeline-desc">${tA[idx]}</div></div>`; }
            h += wrap(`<div class="sec-title">📈 향후 10년 운명 타임라인</div><div class="detail-text"><p><b class="basis-text">순환하는 십이지신의 기운을 반영하여 도출된 정밀 운로입니다.</b></p><div class="timeline">${timelineHtml}</div></div>`);

        } else if (type === 'star') {
            const z = d.zodiac;
            h += wrap(`<div class="summary-box">"원소 기호 [${z.element}]의 에너지를 품은 영혼"</div>
                <div class="stat-grid" style="margin-bottom:40px;">
                    <div class="stat-item"><span class="stat-label">수호 행성</span><span class="stat-val">${z.planet}</span></div>
                    <div class="stat-item"><span class="stat-label">소울메이트</span><span class="stat-val">${z.match}</span></div>
                </div>`);
            h += UI_Section(`우주적 지문: ${z.sign}자리`, "본연의 기질과 영혼의 색깔:", z.trait);
            h += UI_Section("💰 부의 끌어당김", "재물운 흐름:", z.wealth);
            h += UI_Section("💼 별이 내린 천직", "직업적 소명:", z.career);
            h += UI_Section("❤️ 운명적 끌림", "파트너십과 사랑:", z.love);
            
        } else if (type === 'tojeong') {
            // [복구] 토정비결 디자인
            const poem = MYSTIC_DATA.TOJEONG_DB.poems[(d.tj.u+d.tj.md+d.seed) % MYSTIC_DATA.TOJEONG_DB.poems.length];
            const p3 = d.tj.lw===1?"초심을 잃지 마십시오.":d.tj.lw===2?"이웃에게 베풀 때 행운이 정착합니다.":"자기 관리와 절제를 유지하세요.";
            h += wrap(`<div class="tj-code-wrap"><span class="code">No. ${d.tj.c}</span></div>
                <div class="tj-poem-box">
                    <div class="tj-poem-hanja">${poem.hj}</div>
                    <div class="tj-poem-ko">"${poem.kr}"</div>
                    <p style="margin-top:10px; color:var(--text-muted);">${poem.desc}</p>
                </div>`);
            
            h += UI_Section("신수(身數) 심층 리포트", "올해의 전체적인 흐름:", `<br><br>${MYSTIC_DATA.TOJEONG_DB.tA[d.tj.u]}<br><br>${MYSTIC_DATA.TOJEONG_DB.tB[d.tj.md]}<br><br>${p3}`);
            
            let mHtml = '<div style="margin-top:30px;">';
            let ls = parseInt(d.tj.c)+d.seed;
            for(let i=1;i<=12;i++){ 
                ls+=(i*7); let rnd = Math.sin(ls)*10000; rnd=rnd-Math.floor(rnd); 
                let t = MYSTIC_DATA.TOJEONG_DB.mP[Math.floor(rnd*MYSTIC_DATA.TOJEONG_DB.mP.length)];
                let s = 70+Math.floor((Math.sin(ls*i)+1)*14);
                mHtml += `<div class="tj-month-card">
                            <div class="tj-month-header"><span class="tj-month-num">${i}월</span><span style="margin-left:auto; font-size:0.85rem; color:var(--accent-gold-light);">지수: ${s}%</span></div>
                            <div class="tj-month-text">${t}</div>
                          </div>`;
            }
            mHtml += '</div>';
            h += UI_Section("12개월 정밀 타임라인", "월별 상세 브리핑:", "", mHtml);
            
        } else if (type === 'tarot_result') {
            // [복구] 타로 비주얼 큰 이미지 박스
            h += wrap(`<div class="sec-title">메이저 아르카나 심층 리딩</div>`);
            const labels = ["과거의 유산", "현재의 파동", "미래의 결속"];
            const keys = ["past", "present", "future"];
            d.tarotRes.forEach((c,i) => {
                h += wrap(`<div style="margin-bottom:80px; text-align:center;">
                        <span style="color:var(--accent-gold-light); font-weight:700; display:block; margin-bottom:20px;">✦ ${labels[i]} ✦</span>
                        <div class="tarot-visual"><b>${c.icon}</b><span>${c.name}</span></div>
                        <div class="detail-text" style="text-align:justify;">
                            <div class="summary-box" style="margin:20px 0;">"${c.msg}"</div>
                            <p>${c[keys[i]]}</p>
                            <div style="background:rgba(212,175,55,0.06); padding:25px; border-radius:20px; border-left:4px solid var(--accent-gold); text-align:left;">
                                <b style="color:var(--accent-gold-light); display:block; margin-bottom:10px;">💡 무의식의 1:1 조언</b>
                                <span>${c.advice}</span>
                            </div>
                        </div>
                    </div>`);
            });
        }

        // 개운템
        let itemOh = d.oh; if(type==='star') itemOh = d.zodiac.element;
        const cLuck = getSingleKeywordLuck(itemOh);
        h += wrap(`<div class="action-box">
            <h2>✨ 운명을 바꾸는 처방</h2>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin:20px 0;">
                <div style="background:rgba(0,0,0,0.3); padding:15px; border-radius:15px; border:1px solid var(--card-border);">컬러<br><b style="color:var(--accent-gold-light); font-size:1.2rem;">${cLuck.color}</b></div>
                <div style="background:rgba(0,0,0,0.3); padding:15px; border-radius:15px; border:1px solid var(--card-border);">방위<br><b style="color:var(--accent-gold-light); font-size:1.2rem;">${cLuck.dir}</b></div>
                <div style="background:rgba(0,0,0,0.3); padding:15px; border-radius:15px; border:1px solid var(--card-border);">숫자<br><b style="color:var(--accent-gold-light); font-size:1.2rem;">${cLuck.num}</b></div>
            </div>
            <a href="https://www.coupang.com/np/search?q=${encodeURIComponent(cLuck.name)}&utm_source=affiliate" target="_blank" class="btn-rec">🛍️ ${cLuck.icon} ${cLuck.label} [ ${cLuck.name} ] 찾기</a>
            <div style="margin-top:20px; font-size:0.75rem; color:var(--text-muted); opacity:0.6;">이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.</div>
        </div>`);

        document.getElementById('report-content').innerHTML = h;
        setTimeout(() => { document.querySelectorAll('.fade-in-section').forEach(s => s.classList.add('is-visible')); }, 100);
        window.scrollTo({top:0, behavior:'smooth'});
    }

    function renderDeck() {
        const area=document.getElementById('tarot-spread-area'); area.innerHTML=''; tarotChoices=[];
        let currentTarotDeck = [...MYSTIC_DATA.TAROT_DB].sort(()=>0.5-Math.random());
        for(let i=0; i<22; i++){
            const c=document.createElement('div'); c.className='tarot-card-container'; 
            c.onclick=()=>pickTarot(i, currentTarotDeck);
            c.innerHTML=`<div class="tarot-card-inner" id="t-inner-${i}"><div class="tarot-card-front"></div><div class="tarot-card-back" id="t-back-${i}"></div></div>`;
            area.appendChild(c);
        }
    }

    let tarotChoices = [];
    function pickTarot(i, deck) {
        if(tarotChoices.some(c=>c.idx===i) || tarotChoices.length>=3) return;
        tarotChoices.push({idx:i, data:deck[i % deck.length]});
        document.getElementById(`t-back-${i}`).innerText = deck[i % deck.length].icon;
        document.getElementById(`t-inner-${i}`).classList.add('flipped');
        document.getElementById('tarot-count-info').innerText=`3장 중 ${tarotChoices.length}장 선택됨`;
        
        if(tarotChoices.length===3) {
            const l=document.getElementById('loader'), lt=document.getElementById('loader-text');
            l.style.display='flex'; lt.innerText="카드의 파동을 읽는 중...";
            setTimeout(()=>{
                try {
                    const d = calculateBaseData('tarot'); d.tarotRes=tarotChoices.map(c=>c.data);
                    l.style.display='none'; document.getElementById('tarot-pick-view').style.display='none'; document.getElementById('result-view').style.display='block'; 
                    renderFinalReport('tarot_result', d);
                } catch(e) { alert("오류가 발생했습니다."); l.style.display='none'; }
            }, 1500);
        }
    }

    function goHome() { document.getElementById('result-view').style.display='none'; document.getElementById('tarot-pick-view').style.display='none'; document.getElementById('home-view').style.display='block'; window.scrollTo(0,0); }
    function downloadImage() { alert("캡처 준비 완료!"); }
    function shareReport() { alert("링크 복사 완료!"); }

    // ==========================================
    // ★ 5. APP INITIALIZATION & JSON FETCH ★
    // ==========================================
    function initUI() {
        const yS=document.getElementById('user-year'), mS=document.getElementById('user-month'), dS=document.getElementById('user-day');
        if(yS){ for(let i=2024;i>=1940;i--) yS.add(new Option(i+'년', i)); for(let i=1;i<=12;i++) mS.add(new Option(i+'월', i)); for(let i=1;i<=31;i++) dS.add(new Option(i+'일', i)); yS.value=1990; mS.value=1; dS.value=1; }
        document.getElementById('visitor-ui').innerHTML = `🌟 누적 방문자 <b>${Math.floor(Math.random()*1000)+5000}</b>명 돌파`;
    }

    async function loadData() {
        const loader = document.getElementById('loader');
        const mainApp = document.getElementById('main-app');
        
        try {
            const response = await fetch('data.json');
            if (!response.ok) throw new Error('Failed to fetch data.json');
            
            MYSTIC_DATA = await response.json();
            initUI();
            loader.style.display = 'none';
            mainApp.style.display = 'block';
        } catch (error) {
            console.error(error);
            document.getElementById('loader-text').innerText = "데이터 로딩 실패! (로컬 서버 환경을 확인해주세요)";
        }
    }

    window.onload = loadData;

</script>
</body>
</html>

